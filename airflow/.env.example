# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env.

# UID do usuario Linux (rodar: id -u)
AIRFLOW_UID=1000

# Riot Games API Key (expira a cada 24h - renovar em developer.riotgames.com)
RIOT_DEVELOPER_API=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Fernet key para criptografia de conexoes do Airflow
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=

# Databricks Community Edition
# Criar conta em: https://community.cloud.databricks.com/
# Gerar PAT em: Settings > Developer > Access tokens
DATABRICKS_HOST=community.cloud.databricks.com
DATABRICKS_TOKEN=dapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Credenciais do admin do Airflow (opcional - default: airflow/airflow)
# _AIRFLOW_WWW_USER_USERNAME=airflow
# _AIRFLOW_WWW_USER_PASSWORD=airflow
